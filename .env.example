# Optional in local development. Required by default in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MCP_API_KEY=replace-with-a-random-secret

# Comma-separated list of discovered content surface ids.
# The starter content includes: technology, projects.
MCP_ENABLED_SURFACES=technology,projects

# Optional server metadata shown in MCP clients.
# `MCP_SERVER_SLUG` becomes the machine-readable MCP implementation name.
# `MCP_SERVER_NAME` is kept as the human-readable base title for deployer familiarity.
MCP_SERVER_SLUG=knowledgebase-mcp
MCP_SERVER_NAME=Open MCP Knowledgebase
MCP_SERVER_DESCRIPTION=Static Markdown knowledgebase exposed through the Model Context Protocol.
MCP_PUBLIC_URL=http://localhost:3000
# MCP_WEBSITE_URL=https://your-project.vercel.app
# MCP_ICON_URL=/icon.svg
# MCP_ICON_MIME_TYPE=image/svg+xml
# MCP_ICON_SIZES=any
# MCP_ICON_THEME=dark

# Optional surface-specific metadata overrides. Use the uppercased surface id.
# MCP_TECHNOLOGY_SERVER_TITLE=Open MCP Knowledgebase - Technology Documentation
# MCP_PROJECTS_SERVER_TITLE=Open MCP Knowledgebase - Project Documentation

# Set false only for local demos or trusted private networks.
MCP_REQUIRE_AUTH=true

# Compatibility fallback for MCP clients that cannot send Authorization headers.
# Keep false for production unless you specifically need query-string API keys.
MCP_ALLOW_QUERY_API_KEY=false

# Reject POST requests with content-length above this byte count before the MCP
# handler reads the body. Raise only if you intentionally expose large tools.
# MCP_MAX_REQUEST_BYTES=1500000

# Optional client-visible MCP protocol log notifications. Operational logs still
# use Pino. Keep disabled unless you have tested notifications in Inspector.
# MCP_ENABLE_PROTOCOL_LOGGING=false
# MCP_PROTOCOL_LOG_RATE_LIMIT_MAX=10
# MCP_PROTOCOL_LOG_RATE_LIMIT_WINDOW_MS=60000

# Optional provider keys. The base deployment works without these.
# MIXEDBREAD_API_KEY=
# TWELVELABS_API_KEY=

# Optional passthrough tools. Surfaces opt into built-in passthrough tools
# through root _meta.yaml, then env vars decide whether those tools register.
# write_content proxies final prose generation through Vercel AI Gateway.
# MCP_ENABLE_WRITE_CONTENT=false
# AI_GATEWAY_API_KEY=
# MCP_WRITE_CONTENT_MODEL=google/gemini-3.1-pro-preview
# MCP_WRITER_CONTEXT=Write in a clear, practical, grounded style.

# Optional provider runtime guards. These are best-effort in serverless runtimes
# because each function instance keeps its own in-memory counters.
# MCP_PROVIDER_TIMEOUT_MS=30000
# MIXEDBREAD_TIMEOUT_MS=30000
# TWELVELABS_TIMEOUT_MS=30000
# MCP_PROVIDER_RATE_LIMIT_MAX=30
# MCP_PROVIDER_RATE_LIMIT_WINDOW_MS=60000
# MIXEDBREAD_RATE_LIMIT_MAX=30
# TWELVELABS_RATE_LIMIT_MAX=30

# Legacy alias for MCP_ENABLE_WRITE_CONTENT. Prefer MCP_ENABLE_WRITE_CONTENT.
# MCP_ENABLE_WRITER=false

# Optional tuning.
# LOG_LEVEL=info
